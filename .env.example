EXPERT_JWT_SECRET=change-me
EXPERT_PLATFORM_ACTIVATION_TOKEN_TTL_SECONDS=604800
EXPERT_DEFAULT_TENANT_ID=tenant_default
EXPERT_DATABASE_URL=sqlite:///./data/experts-backend.sqlite3
EXPERT_DATABASE_AUTO_MIGRATE=true
EXPERT_DATABASE_SCHEMA_DIR=./infra/sql

# agent-gateway ACP data plane. The route prefix is the gateway's external path prefix for the
# ACP route; the client posts to <prefix>/turn and <prefix>/permission, and reads history from
# <prefix>/sessions and <prefix>/sessions/{id}/transcript (all route-scoped, authenticated by
# ACP_AUTH_TOKEN).
EXPERT_ACP_GATEWAY_BASE_URL=http://127.0.0.1:8080
EXPERT_ACP_ROUTE_PREFIX=
EXPERT_ACP_AUTH_TOKEN=
EXPERT_ACP_CLIENT_ID=experts-backend
EXPERT_ACP_DEFAULT_MODEL=
EXPERT_ACP_DEFAULT_CWD=/tmp/experts-backend
# Per-tenant working dirs: each session uses <base>/<tenant_id> (created on demand).
# Leave empty to share ACP_DEFAULT_CWD. Must resolve under the ACP service's allowedRoots.
EXPERT_ACP_CWD_BASE=

# Object storage for documents, library files and skill packages. Local is the default for
# development and single-node deployments. Set this to minio for production.
EXPERT_OBJECT_STORAGE_BACKEND=local
EXPERT_OBJECT_STORAGE_LOCAL_DIR=./.data/objects
EXPERT_OBJECT_STORAGE_MAX_UPLOAD_BYTES=104857600
# Optional public API origin used when OBJECT_STORAGE_BACKEND=local. Leave empty for same-origin
# relative URLs such as /api/v1/storage/objects/<token>.
EXPERT_OBJECT_STORAGE_PUBLIC_BASE_URL=

# MinIO object storage, used when OBJECT_STORAGE_BACKEND=minio.
EXPERT_MINIO_ENDPOINT=127.0.0.1:9000
EXPERT_MINIO_ACCESS_KEY=minioadmin
EXPERT_MINIO_SECRET_KEY=minioadmin
EXPERT_MINIO_BUCKET=expert-files
EXPERT_MINIO_SECURE=false
