EXPERT_NEXT_JWT_SECRET=change-me
EXPERT_NEXT_PLATFORM_ACTIVATION_TOKEN_TTL_SECONDS=604800
EXPERT_NEXT_DEFAULT_TENANT_ID=tenant_default
EXPERT_NEXT_DATABASE_URL=sqlite:///./data/amazon-experts-backend.sqlite3
EXPERT_NEXT_DATABASE_AUTO_MIGRATE=true
EXPERT_NEXT_DATABASE_SCHEMA_DIR=./infra/sql

# PageIndex adapter. Choose cloud API, self-hosted HTTP wrapper, or replace
# app/clients/pageindex.py with direct SDK calls.
EXPERT_NEXT_PAGEINDEX_BASE_URL=
EXPERT_NEXT_PAGEINDEX_API_KEY=

# agent-gateway ACP data plane. The route prefix is the gateway's external path prefix for the
# ACP route; the client posts to <prefix>/turn and <prefix>/permission, and reads history from
# <prefix>/sessions and <prefix>/sessions/{id}/transcript (all route-scoped, authenticated by
# ACP_AUTH_TOKEN).
EXPERT_NEXT_ACP_GATEWAY_BASE_URL=
EXPERT_NEXT_ACP_ROUTE_PREFIX=
EXPERT_NEXT_ACP_AUTH_TOKEN=
EXPERT_NEXT_ACP_CLIENT_ID=amazon-experts-backend
EXPERT_NEXT_ACP_DEFAULT_MODEL=
EXPERT_NEXT_ACP_DEFAULT_CWD=./expert
# Per-tenant working dirs: each session uses <base>/<tenant_id> (created on demand).
# Leave empty to share ACP_DEFAULT_CWD. Must resolve under the ACP service's allowedRoots.
EXPERT_NEXT_ACP_CWD_BASE=

# Object storage for documents, library files and skill packages. Local is the default for
# development and single-node deployments. Set this to minio for production.
EXPERT_NEXT_OBJECT_STORAGE_BACKEND=local
EXPERT_NEXT_OBJECT_STORAGE_LOCAL_DIR=./.data/objects
EXPERT_NEXT_OBJECT_STORAGE_MAX_UPLOAD_BYTES=104857600
# Optional public API origin used when OBJECT_STORAGE_BACKEND=local. Leave empty for same-origin
# relative URLs such as /api/v1/storage/objects/<token>.
EXPERT_NEXT_OBJECT_STORAGE_PUBLIC_BASE_URL=

# MinIO object storage, used when OBJECT_STORAGE_BACKEND=minio.
EXPERT_NEXT_MINIO_ENDPOINT=127.0.0.1:9000
EXPERT_NEXT_MINIO_ACCESS_KEY=minioadmin
EXPERT_NEXT_MINIO_SECRET_KEY=minioadmin
EXPERT_NEXT_MINIO_BUCKET=expert-files
EXPERT_NEXT_MINIO_SECURE=false
