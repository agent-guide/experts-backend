EXPERT_NEXT_JWT_SECRET=change-me
EXPERT_NEXT_PLATFORM_ACTIVATION_TOKEN_TTL_SECONDS=604800
EXPERT_NEXT_DEFAULT_TENANT_ID=tenant_default
EXPERT_NEXT_DATABASE_URL=sqlite:///./data/amazon-experts-backend.sqlite3
EXPERT_NEXT_DATABASE_AUTO_MIGRATE=true
EXPERT_NEXT_DATABASE_SCHEMA_DIR=./infra/sql

# PageIndex adapter. Choose cloud API, self-hosted HTTP wrapper, or replace
# app/clients/pageindex.py with direct SDK calls.
EXPERT_NEXT_PAGEINDEX_BASE_URL=
EXPERT_NEXT_PAGEINDEX_API_KEY=

# ngent HTTP API.
EXPERT_NEXT_NGENT_BASE_URL=http://127.0.0.1:14500
EXPERT_NEXT_NGENT_AUTH_TOKEN=
EXPERT_NEXT_NGENT_CLIENT_ID=amazon-experts-backend
EXPERT_NEXT_NGENT_DEFAULT_AGENT=codex
EXPERT_NEXT_NGENT_DEFAULT_CWD=./expert

# Skill file storage.
EXPERT_NEXT_SKILL_STORAGE_BACKEND=local
EXPERT_NEXT_SKILL_STORAGE_LOCAL_DIR=./data/skills
EXPERT_NEXT_SKILL_STORAGE_PREFIX=skills

# MinIO skill storage, used when EXPERT_NEXT_SKILL_STORAGE_BACKEND=minio.
EXPERT_NEXT_MINIO_ENDPOINT=127.0.0.1:9000
EXPERT_NEXT_MINIO_ACCESS_KEY=minioadmin
EXPERT_NEXT_MINIO_SECRET_KEY=minioadmin
EXPERT_NEXT_MINIO_BUCKET=expert-skills
EXPERT_NEXT_MINIO_SECURE=false
